                <mxCell id="dcAq8rs-jrX9Jow3yP5C-139" value="&lt;ol style=&quot;padding-inline-start: 28px; color: rgb(171, 178, 191); font-family: system-ui, Ubuntu, &amp;quot;Droid Sans&amp;quot;, sans-serif; font-size: 13px; text-align: start;&quot;&gt;&lt;li style=&quot;margin: 4px 0px;&quot;&gt;&lt;p style=&quot;margin: 0px;&quot;&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;&lt;span style=&quot;font-weight: 600;&quot;&gt;Database per school&lt;/span&gt;&lt;br&gt;Each school has its own DB (&lt;code style=&quot;font-family: &amp;quot;Ubuntu Mono&amp;quot;, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;DejaVu Sans Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, monospace; font-size: 10.998px; color: rgb(209, 154, 102); border-color: rgb(209, 154, 102); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space-collapse: preserve; background-color: rgba(255, 255, 255, 0.1);&quot;&gt;school_a_db&lt;/code&gt;,&amp;nbsp;&lt;code style=&quot;font-family: &amp;quot;Ubuntu Mono&amp;quot;, &amp;quot;Liberation Mono&amp;quot;, &amp;quot;DejaVu Sans Mono&amp;quot;, &amp;quot;Courier New&amp;quot;, monospace; font-size: 10.998px; color: rgb(209, 154, 102); border-color: rgb(209, 154, 102); border-style: none; border-width: 0px; border-image: none 100% / 1 / 0 stretch; white-space-collapse: preserve; background-color: rgba(255, 255, 255, 0.1);&quot;&gt;school_b_db&lt;/code&gt;)&lt;/span&gt;.&lt;/p&gt;&lt;/li&gt;&lt;li style=&quot;margin: 4px 0px;&quot;&gt;&lt;p style=&quot;margin: 0px;&quot;&gt;&lt;span style=&quot;font-weight: 600; background-color: light-dark(rgb(24, 26, 31), rgb(0, 0, 0));&quot;&gt;Schema per school&lt;/span&gt;&amp;nbsp;(PostgreSQL)&lt;br&gt;One DB, multiple schemas&lt;span style=&quot;background-color: light-dark(rgb(24, 26, 31), rgb(0, 0, 0));&quot;&gt; &lt;/span&gt;(&lt;code style=&quot;background-color: rgba(255, 255, 255, 0.1); font-family: &amp;quot;Ubuntu